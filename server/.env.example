# Daily 系统环境变量配置
# 复制此文件为 .env 并填写实际值
# 生产环境必须配置所有敏感项，禁止使用默认值

# 服务端口
PORT=3000

# JWT 认证密钥（生产环境必须修改，建议 32 位以上随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token 过期时间
JWT_EXPIRES_IN=7d

# 管理员账号配置（生产环境必须修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password

# CORS 允许的来源（生产环境必须指定具体域名，禁止设置为 *）
# 多个域名用逗号分隔，例如: https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
